# Copy to .env and adjust. All values are optional; defaults are shown.

# HTTP server
# LISTEN_HOST=0.0.0.0
# LISTEN_PORT=28884
# WEB_WORKERS=4
# HTML_TITLE=Atlas Faucet

# Atlas execution node JSON-RPC. CHAIN_ID is auto-discovered when unset.
# RPC_URL=http://127.0.0.1:8545
# CHAIN_ID=1337

# Funded faucet account. Default is the public Atlas dev key (Anvil account #0).
# OVERRIDE THIS for any shared deployment.
# FAUCET_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Amount handed out per successful claim, in wei (1 ATL by default).
# FAUCET_DRIP_WEI=1000000000000000000

# Proof-of-work: POW_PUZZLES sub-puzzles, each POW_BITS leading zero bits.
# Tune so a typical multicore browser takes ~5 s.
# POW_BITS=16
# POW_PUZZLES=480
# POW_TTL_SECS=180
# POW_HMAC_SECRET=            # fixed secret to keep challenges valid across restarts

# Queue: at most this many claims in the system at once (one dispensed at a
# time). Further claims receive HTTP 429.
# FAUCET_QUEUE_CAPACITY=2
# FAUCET_COOLDOWN_SECS=60     # per-address cooldown between claims (0 disables)

# Transaction tuning
# FAUCET_GAS_LIMIT=21000
# FAUCET_GAS_PRICE_WEI=       # fixed gas price; otherwise eth_gasPrice is used
# FAUCET_RECEIPT_TIMEOUT_SECS=30
